# App environment
ENV=production
DEBUG=false
CORS_ORIGINS=https://your-frontend-domain.com

# Google Gemini API key used by /frontend/src/app/api/chat/route.ts
GEMINI_API_KEY=your_gemini_api_key_here

# JWT secret used by the FastAPI auth system
JWT_SECRET_KEY=replace_with_a_long_random_secret

# Optional override for python binary used by ML bridge
# Example: C:\\path\\to\\python.exe
PYTHON_BIN=

# Frontend auth proxy target
NEXT_PUBLIC_BACKEND_URL=http://127.0.0.1:8000
